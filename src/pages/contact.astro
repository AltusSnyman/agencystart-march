---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | AI Agency Mentorship">
  <div class="min-h-screen pt-24 pb-20">
    <section class="max-w-3xl mx-auto px-4 md:px-8 py-20">
      <a href="/" class="text-sm text-accent hover:underline mb-8 inline-block">&larr; Back to Home</a>
      <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4">Contact Us</h1>
      <p class="text-lg text-secondary mb-10 pb-6 border-b border-slate-200">
        Have questions about the AI Agency Mentorship? We're here to help.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="glass-card p-8">
          <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-primary mb-2">Email Us</h3>
          <p class="text-sm text-secondary mb-3">For general inquiries and support:</p>
          <a href="mailto:alt@altcutman.com" class="text-accent font-semibold hover:underline">
            alt@altcutman.com
          </a>
        </div>

        <div class="glass-card p-8">
          <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-primary mb-2">WhatsApp</h3>
          <p class="text-sm text-secondary mb-3">Message us directly:</p>
          <a href="https://wa.me/64212550493" class="text-green-600 font-semibold hover:underline">
            +64 21 255 0493
          </a>
        </div>
      </div>

      <div class="glass-card p-8 mt-6">
        <h3 class="text-xl font-bold text-primary mb-4">Business Details</h3>
        <ul class="space-y-2 text-sm text-secondary">
          <li><strong class="text-primary">Business Name:</strong> Altcutm LLC</li>
          <li><strong class="text-primary">Owner:</strong> Patrick Altcutman Musson</li>
          <li><strong class="text-primary">Address:</strong> Mount Maunganui, Tauranga, New Zealand</li>
        </ul>
      </div>
    </section>
  </div>
</Layout>
