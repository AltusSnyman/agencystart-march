---
---

<section class="section-padding" style="background: linear-gradient(180deg, #F0F9FF 0%, #F8FAFC 100%);">
  <div class="section-container">
    <img src="/assets/ghl-robot1.png" alt="GoHighLevel" class="w-28 mx-auto mb-4 drop-shadow-lg reveal" />
    <h2 class="section-title">Your Own GoHighLevel. Your Brand. $97/mo.</h2>
    <p class="section-subtitle">Our community buying power gives you the full enterprise stack at a fraction of the price.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Card 1: Unlimited Sub-Accounts -->
      <div class="glass-card p-8 text-center reveal">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto">
          <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
          <path d="M2 17l10 5 10-5"></path>
          <path d="M2 12l10 5 10-5"></path>
        </svg>
        <h3 class="text-xl font-bold mt-4 mb-3">Unlimited Sub-Accounts</h3>
        <p class="text-secondary">Create accounts for every client. No per-account fees. Scale your agency without limits.</p>
      </div>

      <!-- Card 2: Fully White-Labelled -->
      <div class="glass-card p-8 text-center reveal reveal-delay-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto">
          <circle cx="13.5" cy="6.5" r="2.5"></circle>
          <path d="M17.5 10.5c1.5 0 2.5 1 2.5 2.5v1H15v-1c0-1.5 1-2.5 2.5-2.5z"></path>
          <path d="M2 19.5l4-12 3 7 3-4 3 4 3-7 4 12"></path>
          <path d="M2 19.5h20"></path>
        </svg>
        <h3 class="text-xl font-bold mt-4 mb-3">Fully White-Labelled</h3>
        <p class="text-secondary">HighLevel logos removed. Your brand, your desktop app, your domain. Clients never see GoHighLevel.</p>
      </div>

      <!-- Card 3: Full API + SaaS Mode -->
      <div class="glass-card p-8 text-center reveal reveal-delay-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto">
          <polyline points="4 17 10 11 4 5"></polyline>
          <line x1="12" y1="19" x2="20" y2="19"></line>
        </svg>
        <h3 class="text-xl font-bold mt-4 mb-3">Full API + SaaS Mode</h3>
        <p class="text-secondary">Resell to clients at your own price. Build a recurring revenue machine with your own SaaS.</p>
      </div>
    </div>

    <!-- Dashboard Image -->
    <div class="glass-card p-2 mt-12 max-w-4xl mx-auto reveal">
      <img
        src="/assets/ghl-dashboard.png"
        alt="GoHighLevel Dashboard"
        class="rounded-2xl shadow-[0_12px_40px_rgba(0,0,0,0.1)] w-full"
      />
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a href="https://checkout.aiagencymentorship.ai/" class="btn-secondary mt-8 inline-block">
        Start For $97/mo
      </a>
    </div>
  </div>
</section>
