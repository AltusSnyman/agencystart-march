<section class="section-padding bg-white">
  <div class="section-container">
    <h2 class="section-title">Running an Agency Shouldn't Cost More Than Your Rent</h2>
    <p class="section-subtitle">Most people quit before they start — buried under software costs and overwhelmed by tools they don't know how to use.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- LEFT: Cost Breakdown -->
      <div class="reveal">
        <div class="glass-card p-8">
          <h3 class="text-xl font-bold mb-6">The Real Cost of Starting</h3>

          <div class="flex justify-between py-3 border-b border-slate-100">
            <span>GoHighLevel CRM</span>
            <span class="text-red-500 font-semibold">$497/mo</span>
          </div>
          <div class="flex justify-between py-3 border-b border-slate-100">
            <span>Automation Tools</span>
            <span class="text-red-500 font-semibold">$100/mo</span>
          </div>
          <div class="flex justify-between py-3 border-b border-slate-100">
            <span>Hosting & Integrations</span>
            <span class="text-red-500 font-semibold">$200/mo</span>
          </div>

          <div class="flex justify-between pt-4 mt-2 border-t-2 border-red-100">
            <span class="text-xl font-bold text-red-600">Total Before Your First Client</span>
            <span class="text-xl font-bold text-red-600">$800+/mo</span>
          </div>

          <div class="bg-green-50/80 border border-green-200/50 rounded-xl p-4 mt-6">
            <p class="text-sm text-green-800 font-medium">With us:</p>
            <p class="text-2xl font-bold text-green-700">$97/mo — everything included</p>
          </div>
        </div>
      </div>

      <!-- RIGHT: Loom Video -->
      <div class="reveal reveal-delay-1">
        <div class="glass-card p-2 overflow-hidden rounded-2xl">
          <iframe
            src="https://www.loom.com/embed/b1c0f217cad34ccbaaba00b882f8c9c6"
            class="w-full aspect-video rounded-xl"
            frameborder="0"
            webkitallowfullscreen
            mozallowfullscreen
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
