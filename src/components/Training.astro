---
// Training.astro — "What's Included" section
---

<section class="section-padding bg-white">
  <div class="section-container">
    <h2 class="section-title">Everything You Need to Launch</h2>
    <p class="section-subtitle">
      Even if you've never built an agency before. Beginner-friendly, step-by-step.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- 1. 400+ Training Videos -->
      <div class="glass-card p-6 flex flex-col items-start reveal">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-accent">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
            <path d="M6 12v5c0 1.1 2.7 2 6 2s6-.9 6-2v-5"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-primary mb-2">400+ Training Videos</h3>
        <p class="text-sm text-secondary leading-relaxed">
          Step-by-step tutorials from absolute basics to advanced strategies.
        </p>
      </div>

      <!-- 2. 5-Day Agency Sprint -->
      <div class="glass-card p-6 flex flex-col items-start reveal reveal-delay-1">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-accent">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"></path>
            <path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path>
            <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"></path>
            <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-primary mb-2">5-Day Agency Sprint</h3>
        <p class="text-sm text-secondary leading-relaxed">
          Follow the structured sprint to set up your agency infrastructure in 5 days.
        </p>
      </div>

      <!-- 3. 123 Niche Snapshots -->
      <div class="glass-card p-6 flex flex-col items-start reveal reveal-delay-2">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-accent">
            <rect x="3" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="3" width="7" height="7" rx="1"></rect>
            <rect x="3" y="14" width="7" height="7" rx="1"></rect>
            <rect x="14" y="14" width="7" height="7" rx="1"></rect>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-primary mb-2">123 Niche Snapshots</h3>
        <p class="text-sm text-secondary leading-relaxed">
          Pre-built funnels, websites, and automations for any industry.
        </p>
      </div>

      <!-- 4. 40+ Automation Blueprints -->
      <div class="glass-card p-6 flex flex-col items-start reveal reveal-delay-3">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-accent">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-primary mb-2">40+ Automation Blueprints</h3>
        <p class="text-sm text-secondary leading-relaxed">
          Plug-and-play N8N and Make.com workflows ready to deploy.
        </p>
      </div>

      <!-- 5. Weekly Live Calls -->
      <div class="glass-card p-6 flex flex-col items-start reveal reveal-delay-4">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-accent">
            <polygon points="23 7 16 12 23 17 23 7"></polygon>
            <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-primary mb-2">Weekly Live Calls</h3>
        <p class="text-sm text-secondary leading-relaxed">
          Get your questions answered. Never feel stuck or alone.
        </p>
      </div>

      <!-- 6. Cold Email Scripts + 100K Leads -->
      <div class="glass-card p-6 flex flex-col items-start reveal reveal-delay-5">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-accent">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-primary mb-2">Cold Email Scripts + 100K Leads</h3>
        <p class="text-sm text-secondary leading-relaxed">
          Start getting clients immediately with proven outreach.
        </p>
      </div>
    </div>
  </div>
</section>
