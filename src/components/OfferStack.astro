---
const lineItems = [
  { name: "Grey-Label GHL Enterprise License", value: "$497/mo" },
  { name: "SaaS Snapshot Collection", value: "$4,997" },
  { name: "123 Niche-Specific Snapshots", value: "$2,297" },
  { name: "40+ N8N Automation Blueprints", value: "$3,500" },
  { name: "Agency Growth Protocol", value: "$2,500" },
  { name: "5-Day Launch Sprint + Community", value: "$997" },
];
---

<section class="section-padding" style="background: linear-gradient(180deg, #EEF2FF 0%, #E0E7FF 30%, #EEF2FF 100%);">
  <div class="max-w-3xl mx-auto px-4">
    <div class="text-center reveal">
      <!-- Robot mascot above -->
      <img src="/assets/ghl-robot2.webp" alt="GoHighLevel" class="w-32 mx-auto mb-6 animate-float drop-shadow-lg" />
      <span class="inline-flex items-center bg-accent/10 text-accent font-semibold text-sm px-4 py-2 rounded-full mb-6">
        The Complete Bundle
      </span>
      <h2 class="text-4xl sm:text-5xl font-bold text-center mb-2">
        Everything. <span class="text-accent">$97/mo.</span>
      </h2>
      <p class="text-lg text-[#64748B] text-center mb-10">
        Current founder's rate. Standard pricing is $197/mo.
      </p>
    </div>

    <div class="bg-white rounded-3xl shadow-[0_16px_64px_rgba(0,0,0,0.08)] border border-slate-200/80 p-8 md:p-10 reveal reveal-delay-1">
      {lineItems.map((item, i) => (
        <div class:list={[
          "flex items-center justify-between py-4",
          i < lineItems.length - 1 ? "border-b border-slate-100" : ""
        ]}>
          <div class="flex items-center gap-3">
            <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <span class="font-medium">{item.name}</span>
          </div>
          <span class="line-through text-[#64748B] text-sm flex-shrink-0 ml-4">{item.value}</span>
        </div>
      ))}

      <div class="my-6 border-t-2 border-dashed border-slate-200"></div>

      <div class="flex justify-between items-center">
        <span class="text-lg font-semibold">Total Value:</span>
        <span class="line-through text-2xl text-[#64748B]">$18,784+</span>
      </div>

      <div class="mt-6 bg-accent/5 rounded-2xl p-6 text-center">
        <p class="text-sm text-[#64748B] mb-1">Your Price:</p>
        <p>
          <span class="text-5xl font-bold text-accent">$97</span>
          <span class="text-xl text-[#64748B]">/month</span>
        </p>
        <p class="text-sm text-green-600 font-medium mt-2">(Save $400/mo instantly)</p>
      </div>

      <div class="mt-6 text-center">
        <a href="https://checkout.aiagencymentorship.ai/" class="btn-cta w-full text-center text-lg py-5 block">
          Claim My $97/mo Spot
        </a>
      </div>

      <div class="mt-4 text-center flex items-center justify-center gap-2">
        <svg class="w-4 h-4 text-[#64748B]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="text-sm text-[#64748B]">30-Day Money-Back Guarantee</span>
      </div>
    </div>

    <p class="mt-6 text-center text-sm text-secondary">
      Standard rate is $197/month. Founder's rate available while community is growing.
    </p>
  </div>
</section>
